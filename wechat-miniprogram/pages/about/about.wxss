/* about.wxss */
.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.about-section {
  background-color: #fff;
  padding: 40rpx;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  text-align: center;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background-color: #f1f8e9;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 30rpx;
}

.logo-text {
  font-size: 80rpx;
}

.app-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
}

.app-desc {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 40rpx;
}

.info-section {
  text-align: left;
  margin-bottom: 40rpx;
  padding: 0 10rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  border-bottom: 2rpx solid #eee;
  padding-bottom: 10rpx;
}

.info-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.feature-list {
  list-style: none;
  padding: 0;
  margin: 0;
}

.feature-list li {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 15rpx;
  line-height: 1.5;
}

.version-info {
  margin-top: 60rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #eee;
  font-size: 26rpx;
  color: #999;
  text-align: center;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .about-section {
    padding: 30rpx;
  }
  
  .app-name {
    font-size: 32rpx;
  }
  
  .section-title {
    font-size: 28rpx;
  }
  
  .info-text,
  .feature-list li {
    font-size: 26rpx;
  }
}