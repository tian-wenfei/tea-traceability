/* result.wxss */
.container {
  padding: 30rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
  font-size: 32rpx;
  color: #666;
}

.tea-info {
  background-color: #fff;
  padding: 40rpx;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.tea-info h3 {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 40rpx;
  text-align: center;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid #eee;
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  margin: 40rpx 0 24rpx 0;
  color: #333;
  border-bottom: 2rpx solid #eee;
  padding-bottom: 12rpx;
}

.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.info-item {
  background-color: #f9f9f9;
  padding: 24rpx;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
}

.info-item strong {
  display: block;
  font-size: 30rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.info-item span {
  font-size: 32rpx;
  color: #333;
  word-break: break-all;
  line-height: 1.5;
}

.steps-list, .distribution-list {
  list-style: none;
  padding: 0;
  margin: 0 0 40rpx 0;
}

.steps-list li, .distribution-list li {
  background-color: #f9f9f9;
  padding: 24rpx 28rpx;
  border-radius: 10rpx;
  margin-bottom: 24rpx;
  border-left: 4rpx solid #4CAF50;
  min-height: auto;
  width: auto;
  display: block;
}

.steps-list li strong, .distribution-list li strong {
  display: block;
  font-size: 32rpx;
  color: #333;
  margin-bottom: 16rpx;
  word-break: break-all;
  white-space: normal;
}

.steps-list li p, .distribution-list li p {
  font-size: 30rpx;
  color: #666;
  margin: 12rpx 0;
  line-height: 1.8;
  word-break: break-all;
  white-space: normal;
  min-height: auto;
}

.empty-info {
  padding: 40rpx;
  background-color: #f9f9f9;
  border-radius: 10rpx;
  font-size: 30rpx;
  color: #999;
  text-align: center;
  margin-bottom: 30rpx;
}

.btn-group {
  margin-top: 60rpx;
}

.btn {
  width: 100%;
  height: 90rpx;
  border-radius: 10rpx;
  font-size: 34rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-secondary {
  background-color: #f0f0f0;
  color: #333;
  border: 2rpx solid #ddd;
}

.btn-secondary:active {
  background-color: #e0e0e0;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .info-grid {
    grid-template-columns: 1fr;
  }
  
  .tea-info h3 {
    font-size: 36rpx;
  }
  
  .section-title {
    font-size: 30rpx;
  }
  
  .info-item {
    padding: 20rpx;
  }
  
  .steps-list li, .distribution-list li {
    padding: 24rpx;
  }
}